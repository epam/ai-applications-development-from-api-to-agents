{
  "realm": "mcp-realm",
  "enabled": true,
  "displayName": "MCP Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 60,
  "refreshTokenMaxReuse": 20,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeout": 1800,
  "roles": {
    "realm": [
      {
        "name": "mcp-tools-access",
        "description": "Grants access to MCP server tools",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "mcp-client",
      "name": "MCP Agent Client",
      "description": "Public PKCE client used by the MCP agent",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:9999/*"
      ],
      "webOrigins": [
        "http://localhost:9999",
        "http://localhost:8008"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ]
    }
  ],
  "users": [
    {
      "username": "mcp-user",
      "email": "mcp-user@example.com",
      "firstName": "MCP",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "mcp-tools-access"
      ]
    },
    {
      "username": "no-access-user",
      "email": "no-access-user@example.com",
      "firstName": "No Access",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": []
    }
  ]
}